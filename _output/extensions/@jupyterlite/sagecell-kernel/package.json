{
  "name": "@jupyterlite/sagecell-kernel",
  "version": "0.4.0",
  "description": "SageCell wrapper kernel for JupyterLite",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension"
  ],
  "homepage": "https://github.com/your-name/jupyterlite-sagecell-kernel",
  "bugs": {
    "url": "https://github.com/jupyterlite/echo-kernel/issues"
  },
  "license": "BSD-3-Clause",
  "author": "JupyterLite Contributors",
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,js,eot,gif,html,jpg,json,png,svg,woff2,ttf}",
    "src/**/*.{ts,tsx}"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-name/jupyterlite-sagecell-kernel.git"
  },
  "scripts": {
    "build": "jlpm build:lib && jlpm build:labextension:dev",
    "build:prod": "jlpm clean && jlpm build:lib:prod && jlpm build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "clean": "jlpm clean:lib",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:labextension": "rimraf jupyterlite_echo_kernel/labextension jupyterlite_echo_kernel/_version.py",
    "clean:all": "jlpm clean:lib && jlpm clean:labextension",
    "install:extension": "jlpm build"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.5.0",
    "@jupyterlite/services": "^0.7.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.5.0",
    "@types/json-schema": "^7.0.11",
    "@types/react": "^18.0.26",
    "@types/react-addons-linked-state-mixin": "^0.14.22",
    "css-loader": "^6.7.1",
    "rimraf": "^5.0.1",
    "source-map-loader": "^1.0.2",
    "style-loader": "^3.3.1",
    "typescript": "~5.0.2",
    "yjs": "^13.5.0"
  },
  "sideEffects": [
    "style/*.css",
    "style/index.js"
  ],
  "styleModule": "style/index.js",
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "jupyterlite_sagecell_kernel/labextension",
    "sharedPackages": {
      "@jupyterlite/services": {
        "bundled": false,
        "singleton": true
      }
    },
    "_build": {
      "load": "static/remoteEntry.2f3d315919c2659317af.js",
      "extension": "./extension",
      "style": "./style"
    }
  }
}
